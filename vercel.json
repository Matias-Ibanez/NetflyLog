{
  "headers": [
    {
      "source": "/(.*)\\.pdf$",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"$1.pdf\""
        },
        {
          "key": "Content-Type",
          "value": "application/octet-stream"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}